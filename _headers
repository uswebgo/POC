/* Global Security Headers */
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/* Manifest - Cache por 1 hora (permite actualizaciones frecuentes) */
/manifest.json
  Cache-Control: public, max-age=3600, must-revalidate
  Content-Type: application/json

/* Service Worker - Cache por 1 hora (permite actualizaciones) */
/sw.js
  Cache-Control: public, max-age=3600, must-revalidate
  Content-Type: application/javascript
  Service-Worker-Allowed: /

/* index.html - NUNCA cachear (siempre versión fresca) */
/index.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0, private
  Pragma: no-cache
  Expires: 0
  ETag: W/"v2-latest"
  Content-Type: text/html; charset=utf-8

/* Assets estáticos (imágenes, fonts, etc) - Cache permanente */
/assets/*
  Cache-Control: public, max-age=31536000, immutable
