{
  "name": "agenda-inteligente",
  "version": "2.0.0",
  "description": "PWA inteligente con Cloudflare Workers + Supabase + Google Apps Script",
  "author": "uswebgo",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/uswebgo/agenda-inteligente.git"
  },
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "npm run build:css && wrangler deploy",
    "deploy:preview": "npm run build:css && wrangler deploy --env staging",
    "build:css": "tailwindcss -i ./input.css -o ./style.css --minify",
    "build:css:watch": "tailwindcss -i ./input.css -o ./style.css --watch",
    "test": "echo 'Add tests here'",
    "serve": "python -m http.server 8000"
  },
  "devDependencies": {
    "@cloudflare/kv-asset-handler": "^0.3.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "wrangler": "^4.93.1"
  },
  "keywords": [
    "agenda",
    "pwa",
    "supabase",
    "cloudflare-workers",
    "google-apps-script",
    "notificaciones",
    "calendario"
  ]
}
